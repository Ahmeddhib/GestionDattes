generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Agriculteur {
  id                String       @id @default(cuid())
  code              String
  cin               String
  nom               String
  prenom            String
  telephone         String?
  adresse           String?
  nbPalmiers        Int
  superficie        Float?
  productionEstimee Float?
  regionId          String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tenantId          String
  Region            Region       @relation(fields: [regionId], references: [id])
  Tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Livraison         Livraison[]
  PretCaisse        PretCaisse[]

  @@unique([tenantId, cin])
  @@unique([tenantId, code])
  @@index([cin])
  @@index([code])
  @@index([nom])
  @@index([regionId])
  @@index([tenantId])
}

model Analyse {
  id            String      @id
  echantillonId String
  dateAnalyse   DateTime    @default(now())
  humidite      Float?
  tauxSucre     Float?
  calibre       String?
  qualite       String?
  observations  String?
  conforme      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  tenantId      String
  Echantillon   Echantillon @relation(fields: [echantillonId], references: [id])
  Tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([dateAnalyse])
  @@index([echantillonId])
  @@index([tenantId])
}

model AuditLog {
  id          String      @id
  actorId     String
  targetId    String?
  action      AuditAction
  description String?
  details     Json?
  createdAt   DateTime    @default(now())
  tenantId    String
  User        User        @relation(fields: [actorId], references: [id])
  Tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([actorId])
  @@index([createdAt])
  @@index([targetId])
  @@index([tenantId])
}

model BonAchat {
  id          String    @id
  numero      String
  prixKg      Float
  montant     Float
  livraisonId String    @unique
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  tenantId    String
  User        User      @relation(fields: [createdById], references: [id])
  Livraison   Livraison @relation(fields: [livraisonId], references: [id])
  Tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, numero])
  @@index([createdById])
  @@index([numero])
  @@index([tenantId])
}

model BonSortie {
  id             String     @id
  numero         String
  dateSortie     DateTime   @default(now())
  quantiteTotale Float
  stockId        String
  typeCaisseId   String
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime
  tenantId       String
  User           User       @relation(fields: [createdById], references: [id])
  StockDate      StockDate  @relation(fields: [stockId], references: [id])
  Tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  TypeCaisse     TypeCaisse @relation(fields: [typeCaisseId], references: [id])

  @@unique([tenantId, numero])
  @@index([createdById])
  @@index([dateSortie])
  @@index([numero])
  @@index([stockId])
  @@index([tenantId])
}

model Client {
  id        String   @id
  nom       String
  telephone String?
  adresse   String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  tenantId  String
  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  Vente     Vente[]

  @@index([nom])
  @@index([tenantId])
}

model Conditionnement {
  id            String     @id
  nombreCaisses Int
  poidsTotal    Float
  stockId       String
  typeCaisseId  String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  tenantId      String
  StockDate     StockDate  @relation(fields: [stockId], references: [id])
  Tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  TypeCaisse    TypeCaisse @relation(fields: [typeCaisseId], references: [id])

  @@index([stockId])
  @@index([tenantId])
  @@index([typeCaisseId])
}

model Echantillon {
  id          String    @id
  code        String
  livraisonId String
  createdAt   DateTime  @default(now())
  tenantId    String
  Analyse     Analyse[]
  Livraison   Livraison @relation(fields: [livraisonId], references: [id])
  Tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([code])
  @@index([livraisonId])
  @@index([tenantId])
}

model Livraison {
  id                  String                @id
  numeroLot           String
  dateLivraison       DateTime
  agriculteurId       String
  typeDateId          String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  tenantId            String
  BonAchat            BonAchat?
  Echantillon         Echantillon[]
  LivraisonTypeCaisse LivraisonTypeCaisse[]
  Agriculteur         Agriculteur           @relation(fields: [agriculteurId], references: [id])
  Tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  TypeDate            TypeDate              @relation(fields: [typeDateId], references: [id])
  Pesee               Pesee?
  PretCaisse          PretCaisse[]
  StockDate           StockDate[]

  @@unique([tenantId, numeroLot])
  @@index([agriculteurId])
  @@index([createdAt])
  @@index([dateLivraison])
  @@index([numeroLot])
  @@index([tenantId])
  @@index([typeDateId])
}

model LivraisonTypeCaisse {
  id           String     @id @default(cuid())
  livraisonId  String
  typeCaisseId String
  quantite     Int
  createdAt    DateTime   @default(now())
  Livraison    Livraison  @relation(fields: [livraisonId], references: [id], onDelete: Cascade)
  TypeCaisse   TypeCaisse @relation(fields: [typeCaisseId], references: [id])

  @@unique([livraisonId, typeCaisseId])
  @@index([livraisonId])
  @@index([typeCaisseId])
}

model Pesee {
  id          String    @id
  poidsBrut   Float
  poidsNet    Float
  tare        Float?
  livraisonId String    @unique
  createdAt   DateTime  @default(now())
  tenantId    String
  Livraison   Livraison @relation(fields: [livraisonId], references: [id])
  Tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PretCaisse {
  id             String      @id
  nombrePrete    Int
  nombreRetourne Int         @default(0)
  statut         StatutPret  @default(EN_COURS)
  datePreT       DateTime    @default(now())
  dateRetour     DateTime?
  observations   String?
  agriculteurId  String
  typeCaisseId   String
  livraisonId    String?
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime
  tenantId       String
  Agriculteur    Agriculteur @relation(fields: [agriculteurId], references: [id])
  User           User        @relation(fields: [createdById], references: [id])
  Livraison      Livraison?  @relation(fields: [livraisonId], references: [id])
  Tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  TypeCaisse     TypeCaisse  @relation(fields: [typeCaisseId], references: [id])

  @@index([agriculteurId])
  @@index([createdById])
  @@index([livraisonId])
  @@index([statut])
  @@index([tenantId])
  @@index([typeCaisseId])
}

model Region {
  id          String        @id @default(cuid())
  nom         String
  code        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenantId    String
  Agriculteur Agriculteur[]
  Tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([code])
  @@index([tenantId])
}

model Role {
  id          String       @id
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  TenantUser  TenantUser[]
}

model StockDate {
  id                 String            @id
  quantite           Float
  quantiteDisponible Float
  dateEntree         DateTime          @default(now())
  typeDateId         String
  livraisonId        String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  tenantId           String
  BonSortie          BonSortie[]
  Conditionnement    Conditionnement[]
  Livraison          Livraison         @relation(fields: [livraisonId], references: [id])
  Tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  TypeDate           TypeDate          @relation(fields: [typeDateId], references: [id])
  Vente              Vente[]

  @@index([dateEntree])
  @@index([livraisonId])
  @@index([tenantId])
  @@index([typeDateId])
}

model Tenant {
  id              String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  name            String
  code            String            @unique
  active          Boolean           @default(true)
  address         String?
  phone           String?
  email           String?
  settings        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now())
  Agriculteur     Agriculteur[]
  Analyse         Analyse[]
  AuditLog        AuditLog[]
  BonAchat        BonAchat[]
  BonSortie       BonSortie[]
  Client          Client[]
  Conditionnement Conditionnement[]
  Echantillon     Echantillon[]
  Livraison       Livraison[]
  Pesee           Pesee[]
  PretCaisse      PretCaisse[]
  Region          Region[]
  StockDate       StockDate[]
  TenantUser      TenantUser[]
  TypeCaisse      TypeCaisse[]
  TypeDate        TypeDate[]
  Vente           Vente[]

  @@index([active])
  @@index([code])
}

model TenantUser {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  tenantId  String
  roleId    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Role      Role     @relation(fields: [roleId], references: [id])
  Tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([roleId])
  @@index([tenantId])
  @@index([userId])
}

model TypeCaisse {
  id                  String                @id
  nom                 String
  poidsKg             Float
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  tenantId            String
  BonSortie           BonSortie[]
  Conditionnement     Conditionnement[]
  LivraisonTypeCaisse LivraisonTypeCaisse[]
  PretCaisse          PretCaisse[]
  Tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nom])
  @@index([tenantId])
}

model TypeDate {
  id          String      @id
  nom         String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  tenantId    String
  Livraison   Livraison[]
  StockDate   StockDate[]
  Tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nom])
  @@index([tenantId])
}

model User {
  id         String       @id
  name       String
  email      String       @unique
  password   String
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  AuditLog   AuditLog[]
  BonAchat   BonAchat[]
  BonSortie  BonSortie[]
  PretCaisse PretCaisse[]
  TenantUser TenantUser[]
  Vente      Vente[]

  @@index([email])
}

model Vente {
  id           String    @id
  date         DateTime  @default(now())
  quantite     Float
  prixUnitaire Float
  montant      Float
  clientId     String
  stockId      String
  createdById  String
  createdAt    DateTime  @default(now())
  tenantId     String
  Client       Client    @relation(fields: [clientId], references: [id])
  User         User      @relation(fields: [createdById], references: [id])
  StockDate    StockDate @relation(fields: [stockId], references: [id])
  Tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdById])
  @@index([date])
  @@index([stockId])
  @@index([tenantId])
}

enum AuditAction {
  CREATE_USER
  UPDATE_USER
  ACTIVATE_USER
  DEACTIVATE_USER
  CHANGE_ROLE
  CREATE_ROLE
  UPDATE_ROLE
  DELETE_ROLE
  CREATE_REGION
  UPDATE_REGION
  DELETE_REGION
  CREATE_AGRICULTEUR
  UPDATE_AGRICULTEUR
  DELETE_AGRICULTEUR
  CREATE_TYPE_DATE
  UPDATE_TYPE_DATE
  DELETE_TYPE_DATE
  CREATE_TYPE_CAISSE
  UPDATE_TYPE_CAISSE
  DELETE_TYPE_CAISSE
  CREATE_LIVRAISON
  UPDATE_LIVRAISON
  DELETE_LIVRAISON
  CREATE_PRET_CAISSE
  RETOUR_PRET_CAISSE
  CREATE_BON_ACHAT
  UPDATE_BON_ACHAT
  CREATE_PESEE
  UPDATE_PESEE
  CREATE_STOCK
  UPDATE_STOCK
  CREATE_CONDITIONNEMENT
  UPDATE_CONDITIONNEMENT
  DELETE_CONDITIONNEMENT
  CREATE_CLIENT
  UPDATE_CLIENT
  CREATE_VENTE
  UPDATE_VENTE
  DELETE_VENTE
  CREATE_BON_SORTIE
  UPDATE_BON_SORTIE
  DELETE_BON_SORTIE
  CREATE_TENANT
  UPDATE_TENANT
  ACTIVATE_TENANT
  DEACTIVATE_TENANT
}

enum StatutPret {
  EN_COURS
  RETOURNE
  INCOMPLET
}
